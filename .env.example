# Required
TG_BOT_TOKEN=your_telegram_bot_token
OPENROUTER_API_KEY=your_openrouter_api_key

# Optional - restrict access to specific user IDs (comma-separated)
# First user is treated as owner
ALLOWED_USERS=123456789,987654321

# Optional - map user IDs to display names (for logging attribution)
# Format: "user_id:Name,user_id:Name"
USER_NAMES=123456789:Alice,987654321:Bob

# Optional - data directory (default: ~/life)
DATA_DIR=/path/to/data

# Optional - model overrides
AGENT_MODEL=openrouter/anthropic/claude-opus-4.5
GEMINI_MODEL=gemini/gemini-3-flash-preview
SEARCH_MODEL=openrouter/x-ai/grok-4.1-fast
